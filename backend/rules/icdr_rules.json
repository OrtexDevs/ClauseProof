[
    {
        "rule_code": "ICDR_ELIG_001",
        "regulation": "ICDR_2018_AMD_2025",
        "chapter": "IX",
        "section_ref": "Regulation 229 - Eligibility",
        "rule_text": "The issuer must have positive EBITDA (operating profit) in at least 2 of the 3 preceding financial years.",
        "validation_logic": {
            "type": "financial_threshold",
            "field": "ebitda",
            "condition": "count_positive_years >= 2",
            "lookback_years": 3
        },
        "category": "eligibility",
        "severity": "mandatory",
        "applicable_to": "sme",
        "applicable_sections": ["FINANCIAL_STATEMENTS"]
    },
